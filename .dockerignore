# Dependencies (installed inside the image from the lockfile)
node_modules

# Build output (regenerated by `pnpm build` in the image)
build

# VCS / caches
.git
.svelte-kit

# Generated assets under static/ are committed; the embeddings generator is
# only needed to regenerate them, not to build the site.
tools

# Environment files
.env*

# Editor / agent config
.claude

# Doc files at the repo root are not needed to build the site.
# (NOTE: src/content/articles/*.md IS needed — these root-only patterns don't
#  match files inside src/ because * doesn't cross path separators.)
*.md

# The build recipe itself doesn't belong in the image context.
Dockerfile
.dockerignore
